OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL_DEBATER=gpt-4o-mini
OPENAI_MODEL_JUDGE=gpt-4o-mini
DEBATE_MIN_ROUNDS=3
DEBATE_MAX_ROUNDS=6
DEBATE_CONVERGENCE_ROUNDS=2
JUDGE_PANEL_SIZE=1
TEMP_DEBATER=0.7
TEMP_JUDGE=0.2
TEMP_BASELINE=0.2
SELF_CONSISTENCY_SAMPLES=9
MAX_OUTPUT_TOKENS=600
OPENAI_TIMEOUT_SECONDS=60
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=false
RUNS_DIR=../runs
PROMPTS_DIR=../prompts
REPORT_ARTIFACTS_DIR=../artifacts
